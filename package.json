{
  "name": "relationflow-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "ops:build": "node ops/build.mjs",
    "dev:web": "npm run dev --workspace @relationflow/web",
    "dev:api": "npm run start:dev --workspace @relationflow/api",
    "build": "npm run build:web",
    "build:web": "npm run build --workspace @relationflow/web",
    "build:api": "npm run build --workspace @relationflow/api",
    "typecheck": "npm run typecheck:web",
    "typecheck:web": "npm run typecheck --workspace @relationflow/web",
    "test": "npm run test:web",
    "test:web": "npm run test --workspace @relationflow/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
