generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  graphJson     String   @default("{\"people\":[],\"relationships\":[]}")
  positionsJson String   @default("{}")
  layoutMode    String   @default("free")
  treeShape     String   @default("grouped")
  treeRootId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
